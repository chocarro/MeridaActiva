# ─────────────────────────────────────────────────────────────────────
# MeridaActiva — Variables de entorno (plantilla)
# ─────────────────────────────────────────────────────────────────────
# Copia este archivo como '.env' y rellena los valores reales.
# NUNCA subas tu .env al repositorio.
# ─────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────
# Obtén estos valores en: https://supabase.com → Proyecto → Settings → API

# URL pública del proyecto Supabase
VITE_SUPABASE_URL=

# Clave anónima (pública) — segura para exponer en el cliente
VITE_SUPABASE_ANON_KEY=

# Clave de servicio (privada) — NUNCA en el cliente, solo en el servidor
# Usada por /api/eliminar-cuenta.js y /api/contacto.js
SUPABASE_SERVICE_ROLE_KEY=

# ── IA / OpenRouter ──────────────────────────────────────────────────
# Obtén tu clave en: https://openrouter.ai/keys
API_KEY_IA=

# ── API local de desarrollo ──────────────────────────────────────────
# Deja vacío en producción (Vercel usa /api/ automáticamente)
# En desarrollo con `npm run dev:full`, el servidor corre en el puerto 3001
VITE_API_BASE_URL=http://localhost:3001
