# Variables de entorno para MeridaActiva
# Copia este archivo a .env y rellena con tus claves reales:
#   cp .env.example .env

# ── Supabase ──────────────────────────────────────────────────────
# Obtenlas en: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://XXXXXXXXXXXXXXXXXXXX.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── OpenRouter ─────────────────────────────────────────────────────
# Clave para las serverless functions (backend).
# Obtén tu clave en: https://openrouter.ai/keys
API_KEY_IA=sk-or-v1-...

# ── Upstash Redis (opcional — rate limiting) ───────────────────────
# Si no tienes estas variables, el rate limiting queda desactivado.
# Obtén las credenciales en: https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://eu1-...upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...
